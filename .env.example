# ============================================================================
# OffPay backend — environment variables
# Copy to .env for local development. On Railway, set these under
# Project → Variables instead of committing a .env file.
# ============================================================================

NODE_ENV=development
PORT=4000
APP_NAME=OffPay
FRONTEND_URL=https://offpay-gamma.vercel.app
# --- Secrets -----------------------------------------------------------------
# IMPORTANT (Railway): after setting these, click the lock icon next to each
# variable in Project → Variables to mark it "sealed". A sealed variable's
# value is hidden from the dashboard UI (shows as ••••) after it's set —
# that's the actual control Railway offers to stop the value being visible to
# anyone who can view the project. Do this for every secret below.
ENCRYPTION_KEY=replace_with_a_long_random_string
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_long_random_string
OFFLINE_TOKEN_SECRET=replace_with_a_long_random_string

# --- Database ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:OLIPyeCoSiLFzoznUDfVEOqyPJdyEkNj@postgres.railway.internal:5432/railway
DB_SSL=false

# --- Persistent file storage (passport photos, NIN slips, utility bills, ads) ---
# REQUIRED in production. Without these, uploaded files are written to local
# disk, which Railway wipes on every redeploy — this is what causes images to
# show up broken in the admin dashboard after a new deployment. Get these
# three values from your Cloudinary dashboard (free tier is sufficient to
# start): https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=vgrhcgqk
CLOUDINARY_API_KEY=qqC6kwg1e4CSXNBp92FVT6ndMTE
CLOUDINARY_API_SECRET=531621777339279
MAX_UPLOAD_MB=5
AD_MAX_UPLOAD_MB=15

# --- Email (Resend, preferred — Railway blocks outbound SMTP on Free/Hobby) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=OffPay <onboarding@resend.dev>
MOCK_OTP_CONSOLE=true

# --- SMTP (fallback only, works locally; blocked on many Railway plans) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=OffPay <no-reply@offpay.app>

# --- Payment/virtual account providers ---
PRIMARY_PROVIDER=flutterwave
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_ENCRYPTION_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_SOURCE_ACCOUNT_NUMBER=
BIGISUB_API_KEY=
RESEND_API_KEY=re_5Wop7Hs1_7tSui5LxsscCza6zkkWKqBDd

# --- Security / OTP ---
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Turn OFF (unset or 'false') before any real launch.
EXPOSE_OTP_IN_RESPONSE=false

# --- Offline transfers ---
OFFLINE_TOKEN_TTL_HOURS=48
OFFLINE_LOCK_PERCENT=60
OFFLINE_AVAILABLE_PERCENT=40

# --- Seed script (first super-admin) ---
SEED_ADMIN_EMAIL=lukmansegun1@gmail.com
SEED_ADMIN_PASSWORD=luselove
