# ---------------------------------------------------------------------------
# OffPay Backend - Environment Variables
# Copy this file to `.env` and fill in real values before running the app.
# On Railway, set these under Project > Variables instead of committing .env
# ---------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=4000
APP_NAME=OffPay
FRONTEND_URL=http://localhost:3000

# Database (Railway auto-provides DATABASE_URL when you attach a Postgres plugin)
DATABASE_URL=postgresql://postgres:password@localhost:5432/offpay
DB_SSL=false

# JWT / Sessions
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Offline wallet token (signs the offline spending authorization issued to devices)
OFFLINE_TOKEN_SECRET=replace_with_another_long_random_string
OFFLINE_TOKEN_TTL_HOURS=48

# Offline lock configuration
OFFLINE_LOCK_PERCENT=60
OFFLINE_AVAILABLE_PERCENT=40

# Password / OTP
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Admin bootstrap (used once by db/seed.js to create the first super-admin)
SEED_ADMIN_EMAIL=admin@offpay.app
SEED_ADMIN_PASSWORD=ChangeMe!2026

# Mock email transport (swap for real SMTP / SendGrid / Termii in production)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OffPay <no-reply@offpay.app>"
MOCK_OTP_CONSOLE=true

# SMS provider (mock — plug in Termii / Africa's Talking / Twilio)
SMS_PROVIDER=mock

# Payment providers - Flutterwave (primary)
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_ENCRYPTION_KEY=
FLW_BASE_URL=https://api.flutterwave.com/v3

# Payment providers - Paystack (fallback)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co

# Provider strategy: "flutterwave" | "paystack" — which one to try first
PRIMARY_PROVIDER=flutterwave

# File uploads
MAX_UPLOAD_MB=5
